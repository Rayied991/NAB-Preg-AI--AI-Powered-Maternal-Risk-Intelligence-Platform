services:

  backend:
    build:
      context: ../..
      dockerfile: infra/docker/backend.Dockerfile

    ports:
      - "8000:8000"

    env_file:
      - ../../backend/.env

    networks:
      - nabpreg

  frontend:
    build:
      context: ../..
      dockerfile: infra/docker/frontend.Dockerfile

    ports:
      - "3000:3000"

    env_file:
      - ../../frontend/.env.local

    depends_on:
      - backend

    networks:
      - nabpreg

networks:
  nabpreg:
    driver: bridge